generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  // Null for passwordless accounts created from a bureau magic link — they sign
  // in via their personal access link, not with a password.
  passwordHash String?
  createdAt    DateTime @default(now())
  events       Event[]
  accounts     Account[]
  sessions     Session[]
  memberships  EventMember[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model Event {
  id          String       @id @default(cuid())
  name        String
  description String?
  date        DateTime?
  location    String?
  // Wall-clock of T0 ("HH:MM"), i.e. the départure of the first wave. Each race
  // starts at T0 + its startTime offset; used to show real arrival times in the
  // report's "FLUX D'ARRIVÉE" section. Null = times shown as T+ offsets only.
  startClock  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  races       Race[]
  simulations Simulation[]
  members     EventMember[]
  partners    Partner[]
  tasks       Task[]
  // Field staffing plan (postes), durable at the event level so it survives
  // across simulations and trace edits. JSON: PlacedLogi[] (geo coords +
  // optional assigned EventMember). If a trace changes, a poste keeps its
  // lat/lng — the organiser deletes & re-places it if it no longer fits.
  implantation String      @default("[]")
}

// Organisation checklist item with an optional deadline (déclaration préfecture,
// convention secours, balisage…). Reminders are derived from dueDate.
model Task {
  id        String    @id @default(cuid())
  eventId   String
  event     Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  title     String
  category  String    @default("GENERAL") // ADMINISTRATIF | SECURITE | LOGISTIQUE | COMMUNICATION | GENERAL
  // Pipeline status. `done` is kept in sync (done = status VALIDE) so existing
  // dashboard reminders keep working without a data migration.
  status    String    @default("EN_ATTENTE") // EN_ATTENTE | EN_COURS | VALIDE | IMPOSSIBLE
  dueDate   DateTime?
  done      Boolean   @default(false)
  doneAt    DateTime?
  // Person responsible: an EventMember id (plain reference; name resolved in the
  // UI from the member list, so deleting a member can't cascade-delete a task).
  assigneeId String?
  // Budget: estimated vs actual cost (lots, chrono, médecin…). Null = no amount.
  amountEstimated Float?
  amountActual    Float?
  // Sub-task support: a task can belong to a parent task (one level expected).
  parentId  String?
  parent    Task?     @relation("SubTasks", fields: [parentId], references: [id], onDelete: Cascade)
  children  Task[]    @relation("SubTasks")
  note      String?
  createdAt DateTime  @default(now())
}

// A person attached to an event: co-organiser, volunteer… The record can exist
// without an account (name/phone only); claiming the invite link binds a userId
// and gives that person access to the event according to their role.
model EventMember {
  id          String   @id @default(cuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  name        String
  email       String?
  phone       String?
  // ORGANISATEUR (manage everything except deleting the event) | BENEVOLE (read)
  role        String   @default("BENEVOLE")
  // INVITE (created, link not claimed) | ACTIF (claimed by a user account)
  status      String   @default("INVITE")
  inviteToken String   @unique @default(cuid())
  // Courses this person is assigned to (JSON array of race ids; [] = none yet).
  raceIds     String   @default("[]")
  note        String?
  createdAt   DateTime @default(now())

  @@unique([eventId, userId])
}

// Partner organisation of an event (sponsor, mairie, secours, presse…).
model Partner {
  id          String   @id @default(cuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name        String
  kind        String   @default("SPONSOR") // SPONSOR | INSTITUTION | SECOURS | PRESSE | AUTRE
  contactName String?
  email       String?
  phone       String?
  note        String?
  createdAt   DateTime @default(now())
}

model Race {
  id         String    @id @default(cuid())
  name       String
  distance   Float     @default(0)
  elevGain   Int       @default(0)
  elevLoss   Int       @default(0)
  startTime  Int       @default(0)
  // Barrière horaire / temps limite: minutes from THIS race's départure after
  // which the course closes. Null = no cut-off configured. Display-only (drawn
  // on the report's finish-flow chart + "hors délai" count); does not affect the
  // engine.
  cutoffMinutes Int?
  gpxRaw     String?
  gpxPoints  String    @default("[]")
  color      String    @default("#7CB518")
  eventId    String
  event      Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  segments   Segment[]
}

model Segment {
  id         String  @id @default(cuid())
  raceId     String
  race       Race    @relation(fields: [raceId], references: [id], onDelete: Cascade)
  indexStart Int     @default(0)
  indexEnd   Int     @default(0)
  lengthM    Int     @default(200)
  type       String  @default("NARROW")
  label      String?
  width      Float   @default(1.0)
  techLevel  Int     @default(1)
  // RAVITO only: pause imposed at this point, in seconds. Null = use each
  // runner profile's ravitoDuration (per-archetype default).
  ravitoSec  Int?
  note       String?
  lat        Float   @default(0)
  lng        Float   @default(0)
}

model Simulation {
  id             String          @id @default(cuid())
  name           String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  eventId        String
  event          Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  totalRunners   Int             @default(300)
  status         String          @default("PENDING")
  temperature    Float           @default(18.0)
  wind           Float           @default(0.0)
  windDirection  Float           @default(0.0)
  rain           Boolean         @default(false)
  rainIntensity  Float           @default(0.0)
  fog            Boolean         @default(false)
  jamThreshold   Int             @default(10)
  affluenceThreshold Int         @default(15)
  nRuns          Int             @default(100)
  resultSnapshot String?
  riskMap        String?
  logistique     String          @default("[]")
  peloton        String?
  // Snapshot of the courses' départs at launch time (JSON: [{id,name,distance,startTime}]),
  // so the history shows the start offsets THIS run actually used, even if the
  // race.startTime is edited afterwards.
  racesSnapshot  String?
  // Snapshot of each course's trace + segments at launch (JSON:
  // [{id, gpxPoints, segments}]). Runner positions are stored as fractions of
  // the trace, so results/report/terrain must render the geometry THIS run
  // used — not the live Race row, which may have been re-uploaded since.
  gpxSnapshot    String?
  ressources     String          @default("{\"effectifTotal\":45,\"barrieres\":20}")
  runnerProfiles RunnerProfile[]
}

model RunnerProfile {
  id             String     @id @default(cuid())
  label          String
  percentage     Float
  baseSpeedMin   Float      @default(7)
  baseSpeedMax   Float      @default(10)
  climbCoeff     Float      @default(1.0)
  descentCoeff   Float      @default(1.0)
  fatigueFactor  Float      @default(0.8)
  techSkill      Float      @default(0.7)
  ravitoDuration Int        @default(90)
  abandonRate    Float      @default(0.1)
  color          String     @default("#888780")
  simulationId   String
  simulation     Simulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)
}
